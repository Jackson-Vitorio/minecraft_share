# -*- mode: python ; coding: utf-8 -*-

block_cipher = None

a = Analysis(
    ['mundosync.py'],
    pathex=[],
    binaries=[('rclone.exe', '.')],   # empacota o rclone junto
    datas=[],
    hiddenimports=[],
    hookspath=[],
    runtime_hooks=[],
    excludes=[],
    win_no_prefer_redirects=False,
    win_private_assemblies=False,
    cipher=block_cipher,
    noarchive=False,
